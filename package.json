{
  "name": "project-moderator",
  "version": "1.0.0",
  "description": "Decoupled Discord moderation bot with webhook ingestion and interactive log messages",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "npm run build && node --env-file=.env.development --watch dist/bot/bot.js",
    "stage": "node --env-file=.env.staging dist/index.js",
    "prod": "node --env-file=.env.production dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@types/pg": "^8.11.11",
    "discord.js": "^14.16.3",
    "express": "^4.21.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.14",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}