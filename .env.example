ENVIRONMENT=dev

# Discord — from the Discord Developer Portal
DISCORD_TOKEN=
BOT_ID=
CLIENT_ID=
GUILD_ID=

# database-service
DS_URL=http://localhost:3000/api/v1
MS_API_SECRET=

# Incoming webhook auth — callers must send this as a Bearer token
WEBHOOK_SECRET=

# Discord webhook URLs for logging (optional)
DISCORD_LOG_WEBHOOK_URL=
DISCORD_ERROR_WEBHOOK_URL=

# Discord channel IDs
TRUTHS_CHANNEL_ID=
DARES_CHANNEL_ID=

# Express API port
PORT=4001
